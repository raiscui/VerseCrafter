# flash-attn 源码编译默认至少预留 4 个 CPU, 避免 bootstrap 把整机打满.
export FLASH_ATTN_RESERVED_CPUS="${FLASH_ATTN_RESERVED_CPUS:-4}"

# 留空时自动探测当前 GPU 架构, 默认只编这一套专用版本.
# 如需手动覆盖, 可写成类似 120 这样的值.
export FLASH_ATTN_CUDA_ARCHS="${FLASH_ATTN_CUDA_ARCHS:-}"

# pytorch3d 源码编译同样默认至少预留 4 个 CPU.
# 如需更保守, 可以把这个值调大; 如需更激进, 可以调小.
export PYTORCH3D_RESERVED_CPUS="${PYTORCH3D_RESERVED_CPUS:-4}"

# pytorch3d 默认按官方文档使用 released `stable` 引用, 避免每次都追 `main`.
# 如需切到其他分支 / tag / commit, 可显式覆盖这个变量.
export PYTORCH3D_GIT_REF="${PYTORCH3D_GIT_REF:-stable}"

# 默认优先绑定系统编译器, 减少 Conda / Pixi toolchain 与 CUDA host compiler 的不一致.
# 设为 0 可关闭这条自动策略.
export PYTORCH3D_USE_SYSTEM_COMPILER="${PYTORCH3D_USE_SYSTEM_COMPILER:-1}"

# 留空时脚本会尝试从 `nvcc` 或 `/usr/local/cuda*` 自动推断 CUDA_HOME.
# 如果你要显式指定, 这里必须写“真实存在且包含 bin/nvcc 的 toolkit 根目录”.
export PYTORCH3D_CUDA_HOME="${PYTORCH3D_CUDA_HOME:-}"

# 留空时脚本只会在“Blackwell + PyTorch 2.7+ + CUDA 12.8+”的明确场景下自动写入 `12.0`.
# 其它环境保持不设值, 避免把旧 torch 不认识的架构硬塞进去.
export PYTORCH3D_TORCH_CUDA_ARCH_LIST="${PYTORCH3D_TORCH_CUDA_ARCH_LIST:-}"

# Grounded-SAM-2 的 editable 安装默认也会尝试编译扩展, 同样预留 4 个 CPU.
export SAM2_RESERVED_CPUS="${SAM2_RESERVED_CPUS:-4}"

# 如需完全手动指定编译并发, 可以自行取消注释并调整数值.
# 注意: MAX_JOBS 会同时影响 flash-attn / pytorch3d / Grounded-SAM-2 这类基于 torch cpp extension / ninja 的构建.
# export MAX_JOBS=8

# 如需强制重装 pytorch3d, 可取消注释.
# 默认会在检测到已安装时直接短路成功, 避免重复触发重编译.
# export PYTORCH3D_FORCE_REINSTALL=1
export OMP_NUM_THREADS=16